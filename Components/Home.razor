@using BorchePortfolio.Services

@page "/"

<PageTitle>Startseite</PageTitle>

<div class="modern-hero">
    <div class="modern-hero-bg"></div>

    <div class="modern-hero-content">
        <div class="modern-hero-left">
            <div class="badge-line">
                <span class="hero-badge">Softwareentwickler</span>
                <span class="hero-badge hero-badge-outline">Linz, Oberösterreich</span>
            </div>

            <h1>Borche Mladenovski</h1>

            <h2>
                Moderne Softwarelösungen mit C#,.NET, WPF, XAML, MVVM,
                Blazor, APIs und SQL-Datenbanken
            </h2>

            <p class="hero-description">
                Ich entwickle professionelle Desktop- und Webanwendungen
                mit Fokus auf saubere Architektur, moderne Benutzeroberflächen,
                stabile Datenverarbeitung und praxisnahe Lösungen.
            </p>

            <div class="hero-actions">
                <a class="hero-btn hero-btn-primary" href="contact">Kontakt aufnehmen</a>
                <a class="hero-btn hero-btn-secondary" href="admin-login">Admin Bereich</a>
            </div>

            <div class="hero-stats">
                <div class="stat-card">
                    <h3>3+</h3>
                    <p>Jahre Erfahrung</p>
                </div>

                <div class="stat-card">
                    <h3>C#</h3>
                    <p>WPF, Blazor, APIs</p>
                </div>

                <div class="stat-card">
                    <h3>SQL</h3>
                    <p>Datenbanken & EF Core</p>
                </div>
            </div>
        </div>

        <div class="modern-hero-right">
            <div class="profile-card">
                <div class="profile-image-wrap">
                    <img src="Image/BM.png" alt="Borche Mladenovski" class="profile-image" />
                </div>

                <div class="profile-card-content">
                    <h3>Softwareentwickler</h3>
                    <p>
                        C#,.NET, WPF, XAML, MVVM, Blazor, API-Entwicklung
                        und SQL-Datenbanken
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="info-section">
    <div class="info-card">
        <h3>Über mich</h3>
        <p>
            Ich bin ein Softwareentwickler mit 3 Jahren Erfahrung in der Entwicklung
            moderner Anwendungen. Mein Schwerpunkt liegt auf wartbaren Architekturen,
            klaren Benutzeroberflächen und performanten Lösungen im .NET-Umfeld.
        </p>
    </div>

    <div class="info-card">
        <h3>Kerntechnologien</h3>
        <ul class="tech-list">
            <li>C# / .NET</li>
            <li>WPF / XAML</li>
            <li>XAML</li>
            <li>MVVM</li>
            <li>Blazor</li>
            <li>REST APIs</li>
            <li>SQL Server</li>
            <li>Entity Framework Core</li>
        </ul>
    </div>

    <div class="info-card info-card-wide">
        <h3>Projektfokus</h3>
        <p>
            Zu meinen Projekten gehört unter anderem ein ERP UI System mit
            C#,.NET, WPF, XAML, MVVM, Datenbank und API-Anbindung. Dabei verbinde ich
            Benutzeroberfläche, Business-Logik und Datenhaltung in einer
            vollständigen Softwarelösung.
        </p>
    </div>
</section>

<section class="projects-section">
    <div class="section-heading">
        <span class="section-label">Projekte</span>
        <h2>Ausgewählte Projektschwerpunkte</h2>
        <p>
            Ein Überblick über Technologien und Projekterfahrungen,
            die meinen Schwerpunkt als Softwareentwickler definieren.
        </p>
    </div>

    <div class="projects-grid">
        <div class="project-card">
            <div class="project-tag">ERP</div>
            <h3>ERP UI System</h3>
            <p>
                Entwicklung eines strukturierten ERP-Systems mit C#,.NET, WPF, XAML,
                MVVM, Datenbank und API-Anbindung. Fokus auf klare Bedienung,
                wartbare Architektur und stabile Geschäftsprozesse.
            </p>
            <div class="project-stack">
                <span>C#</span>
                <span>.NET</span>
                <span>WPF</span>
                <span>XAML</span>
                <span>MVVM</span>
                <span>SQL</span>
                <span>API</span>
            </div>
        </div>

        <div class="project-card">
            <div class="project-tag">Desktop</div>
            <h3>Moderne Desktop-Anwendungen</h3>
            <p>
                Entwicklung performanter und benutzerfreundlicher Desktop-Lösungen
                mit sauberer UI-Struktur, responsiver Logik und solider Trennung
                zwischen Oberfläche und Geschäftslogik.
            </p>
            <div class="project-stack">
                <span>.NET</span>
                <span>C#</span>
                <span>WPF</span>
                <span>MVVM</span>
            </div>
        </div>

        <div class="project-card">
            <div class="project-tag">Backend</div>
            <h3>API & Datenbankintegration</h3>
            <p>
                Anbindung und Entwicklung von APIs sowie Arbeit mit SQL-Datenbanken
                für zuverlässige Datenverarbeitung, saubere Strukturen und
                stabile Kommunikation zwischen Systemen.
            </p>
            <div class="project-stack">
                <span>REST API</span>
                <span>SQL Server</span>
                <span>EF Core</span>
                <span>Blazor</span>
            </div>
        </div>
    </div>
</section>